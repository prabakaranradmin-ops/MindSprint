{
  "name": "bloom-academy",
  "private": true,
  "version": "0.1.0",
  "description": "Bloom Academy (working title) — kids' educational game prototype + Playwright acceptance tests",
  "scripts": {
    "serve": "node serve.cjs",
    "test": "playwright test",
    "test:unit": "node --test tests/unit/*.test.cjs",
    "test:all": "npm run test:unit && npm run test",
    "report": "playwright show-report",
    "gen:phonemes": "node scripts/gen-phoneme-placeholders.cjs",
    "gen:sw": "node scripts/gen-service-worker.cjs"
  },
  "devDependencies": {
    "@babel/standalone": "^8.0.4",
    "@playwright/test": "^1.49.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
